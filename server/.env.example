# Tencent secret info.
# [Public Cloud]
#   - TC_SECRET_ID and TC_SECRET_KEY
#       - Chinese mainland users: obtain from https://console.cloud.tencent.com/cam/capi
#       - Other regions: obtain from https://console.tencentcloud.com/cam/capi
#   - TC_SECRET_APPID is not required if you don't use ASR service
# [Private Cloud]
#   - TC_SECRET_APPID is not required
#   - TC_SECRET_ID and TC_SECRET_KEY: obtain from the key management page of your private cloud

TC_SECRET_APPID=
TC_SECRET_ID=
TC_SECRET_KEY=


# Application configuration, supports multiple application configurations
# - Vendor: Service provider name, currently only supports Tencent
# - ApplicationId: Unique identifier for the chat application, recommended to use the vendor's appid
# - Comment: Optional display label for multi-app management (non-functional field)
# - AppKey:
#   - Chinese mainland users: obtain from https://adp.cloud.tencent.com/adp/#/app/home
#   - Other regions: obtain from https://adp.tencentcloud.com/adp/#/app/home
# - International: Whether it's international version (false=China mainland, true=other regions)
# - Private: Whether it's private cloud (default false)
# - PrivateUrl: access url of the private cloud, e.g. "http://172.0.0.1", no trailing slash!
#
# [Public Cloud Example]
#   {
#       "Vendor": "Tencent",
#       "ApplicationId": "",
#       "Comment": "",
#       "AppKey": "",
#       "International": false
#   }
#
# [Private Cloud Example]
#   {
#       "Vendor": "Tencent",
#       "ApplicationId": "",
#       "Comment": "",
#       "AppKey": "",
#       "International": false,
#       "Private": true,
#       "PrivateUrl": "http://172.0.0.1"
#   }
APP_CONFIGS='[
    {
        "Vendor":"Tencent",
        "ApplicationId":"",
        "Comment": "",
        "AppKey": "",
        "International": false
    }
]'

# ADP VisitorId source for chat requests.
# - NAME: use the account name as VisitorId (default)
# - CUSTOMER_ID: use the CustomerId from account-system integration as VisitorId, fallback to internal account ID
ADP_VISITOR_ID_TYPE=NAME

# ============================================================
# Common configuration (applies to both Public and Private Cloud)
# ============================================================

# you can obtain it from https://github.com/settings/applications/new
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_SECRET=

# you can obtain it from https://entra.microsoft.com
OAUTH_MICROSOFT_ENTRA_CLIENT_ID=
OAUTH_MICROSOFT_ENTRA_SECRET=
# Endpoint (optional, if you have a tenant id, default: common), see: https://learn.microsoft.com/en-us/entra/identity-platform/authentication-national-cloud
OAUTH_MICROSOFT_ENTRA_ENDPOINT=common

# Whether to automatically create an account for new users
AUTO_CREATE_ACCOUNT=false

# random key to encrypt the user password
SECRET_KEY=

# random key for verifying customer account signatures
CUSTOMER_ACCOUNT_SECRET_KEY=

# Service API base URL(no trailing slash!)
SERVICE_API_URL=http://localhost:8000

# Server listen port, not necessarily same with SERVICE_API_URL
SERVER_HTTP_PORT=8000

# Server response timeout in seconds
SERVER_RESPONSE_TIMEOUT=300

# Access token expiration time in hours
ACCESS_TOKEN_EXPIRE_HOURS=24

LOG_LEVEL=INFO

# Rate limit configuration in format 'requests/period' (e.g., '100/minute')
RATE_LIMIT=100/minute

# Allowed CORS origins. Multiple origins separated by comma, e.g. 'http://localhost,http://127.0.0.1:3000'
CORS_ORIGINS=http://localhost

# Allowed parent origins for iframe embedding via CSP frame-ancestors. Multiple origins separated by comma.
# Leave empty to only allow same-origin embedding.
# When this is set, auth cookie will be issued as SameSite=None; Secure and CORS credentials will be enabled.
IFRAME_ORIGINS=

# postgresql configuration
PGSQL_HOST=adp-chat-client-db-default
PGSQL_PORT=5432
PGSQL_DB=test
PGSQL_USER=postgres
PGSQL_PASSWORD=ye823hd8euhwf
